# Flask
SECRET_KEY=change-me
SESSION_COOKIE_SECURE=false
SESSION_TIMEOUT_MINUTES=30
PERMANENT_SESSION_LIFETIME_DAYS=7

# MongoDB Atlas
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=

# Default admin bootstrap
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Admin

# Default fuel initialization
DEFAULT_PETROL_PRICE=100
DEFAULT_PETROL_STOCK=500
DEFAULT_DIESEL_PRICE=90
DEFAULT_DIESEL_STOCK=600

# Login security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Logging
LOG_LEVEL=INFO

